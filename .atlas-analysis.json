  "keyFeatures": [
    "Role-based access control for coordinators, teachers, and psychologists",
    "Student referral system with observation and strategy tracking",
    "PIAR and DUA student management",
    "Academic structure management (degrees, groups, areas)",
    "Psycho-orientation reporting and documentation",
    "Student history and progress tracking",
    "Email notifications for referral actions",
    "File attachment support for reports and referrals"
  ],
  "publicApiSurface": [
    "POST /store/referral - Create a new student referral",
    "GET /index/students/remitted/psico - List referred students for psychologist",
    "GET /psico/students/active - View active students",
    "GET /psico/students/piar - View PIAR students",
    "GET /psico/students/dua - View DUA students",
    "PUT /accept/student - Accept student to PIAR program",
    "POST /store/report/student/{id} - Create psycho-orientation report",
    "POST /store/user - Create new user (coordinator)",
    "POST /store/degree - Create academic degree",
    "POST /store/group - Create student group",
    "POST /store/area - Create academic area"
  ]
